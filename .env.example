# ============================================
# FFE Social Engine — Environment Variables
# All secrets vaulted in GCP SM (project: ffe-cicd)
# Naming: social-engine-{env}-{var-name}
# ============================================

# --- Clerk Auth (GCP SM: social-engine-{env}-clerk-*) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Convex DB (GCP SM: social-engine-{env}-convex-*) ---
CONVEX_DEPLOYMENT=dev:calm-gnat-491
NEXT_PUBLIC_CONVEX_URL=https://calm-gnat-491.convex.cloud

# --- Social Posting / Zernio (GCP SM: social-engine-{env}-zernio-api-key) ---
ZERNIO_API_KEY=

# --- AI / Gemini (GCP SM: social-engine-{env}-google-api-key) ---
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=

# --- Media Services (local dev or Tailscale to hive) ---
VOICE_SERVICE_URL=http://localhost:8001
VISUAL_SERVICE_URL=http://localhost:8002
COMPOSER_SERVICE_URL=http://localhost:8003
TEXT_SERVICE_URL=http://localhost:8004

# Social posting
AYRSHARE_API_KEY=

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe Auth
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...

# --- Analytics / PostHog (GCP SM: social-engine-{env}-posthog-key) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# --- Error Tracking / Sentry (GCP SM: social-engine-{env}-sentry-dsn) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=firefly-events-inc
SENTRY_PROJECT=social-engine
SENTRY_AUTH_TOKEN=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Stripe 4-tier pricing (FIR-1259) ---
# Free tier has no Stripe price ID (no charge)
# Pro:    $29.99/mo  |  annual discount
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
# Agency: $99/mo     |  annual discount
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...
# Enterprise: custom (managed outside Stripe checkout)
