# ============================================
# FFE Social Engine — Environment Variables
# All secrets vaulted in GCP SM (project: ffe-cicd)
# Naming: social-engine-{env}-{var-name}
# ============================================

# --- Clerk Auth (GCP SM: social-engine-{env}-clerk-*) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Convex DB (GCP SM: social-engine-{env}-convex-*) ---
CONVEX_DEPLOYMENT=dev:calm-gnat-491
NEXT_PUBLIC_CONVEX_URL=https://calm-gnat-491.convex.cloud

# --- Social Posting / Zernio (GCP SM: social-engine-{env}-zernio-api-key) ---
ZERNIO_API_KEY=

# --- AI / Gemini (GCP SM: social-engine-{env}-google-api-key) ---
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=

# --- Media Services (local dev or Tailscale to hive) ---
VOICE_SERVICE_URL=http://localhost:8001
VISUAL_SERVICE_URL=http://localhost:8002
COMPOSER_SERVICE_URL=http://localhost:8003
TEXT_SERVICE_URL=http://localhost:8004

# Social posting
AYRSHARE_API_KEY=

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe Auth
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...

# --- Analytics / PostHog (GCP SM: social-engine-{env}-posthog-key) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# --- Error Tracking / Sentry (GCP SM: social-engine-{env}-sentry-dsn) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=firefly-events-inc
SENTRY_PROJECT=social-engine
SENTRY_AUTH_TOKEN=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# OAuth Token Encryption
# GCP SM: social-engine-dev-oauth-token-encryption-key / social-engine-prod-oauth-token-encryption-key
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
OAUTH_TOKEN_ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# -----------------------------------------------------------------------------
# LinkedIn OAuth
# GCP SM: social-engine-dev-linkedin-client-id / social-engine-prod-linkedin-client-id
# App: https://www.linkedin.com/developers/apps
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=your-linkedin-client-id-here
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret-here

# -----------------------------------------------------------------------------
# Twitter / X OAuth 2.0 (PKCE)
# GCP SM: social-engine-dev-twitter-client-id / social-engine-prod-twitter-client-id
# App: https://developer.twitter.com/en/portal/projects-and-apps
# -----------------------------------------------------------------------------
TWITTER_CLIENT_ID=your-twitter-client-id-here
TWITTER_CLIENT_SECRET=your-twitter-client-secret-here

# -----------------------------------------------------------------------------
# Instagram OAuth (via Facebook App)
# GCP SM: social-engine-dev-instagram-app-id / social-engine-prod-instagram-app-id
# App: https://developers.facebook.com/apps
# -----------------------------------------------------------------------------
INSTAGRAM_APP_ID=your-instagram-app-id-here
INSTAGRAM_APP_SECRET=your-instagram-app-secret-here

# -----------------------------------------------------------------------------
# TikTok OAuth
# GCP SM: social-engine-dev-tiktok-client-key / social-engine-prod-tiktok-client-key
# App: https://developers.tiktok.com/
# -----------------------------------------------------------------------------
TIKTOK_CLIENT_KEY=your-tiktok-client-key-here
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret-here

# -----------------------------------------------------------------------------
# YouTube / Google OAuth
# GCP SM: social-engine-dev-youtube-client-id / social-engine-prod-youtube-client-id
# App: https://console.cloud.google.com/ (OAuth 2.0 Client IDs)
# -----------------------------------------------------------------------------
YOUTUBE_CLIENT_ID=your-youtube-google-oauth-client-id-here
YOUTUBE_CLIENT_SECRET=your-youtube-google-oauth-client-secret-here

# -----------------------------------------------------------------------------
# MongoDB Token Vault
# GCP SM: social-engine-dev-mongodb-uri / social-engine-prod-mongodb-uri
# Used by packages/db/src/mongo.js for field-level encrypted token storage
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/?retryWrites=true&w=majority
# Generate with: openssl rand -base64 32
MONGODB_ENCRYPTION_KEY=<base64-encoded-32-byte-key>
