# =============================================================================
# Social Engine Dashboard — Environment Variables
# =============================================================================
# All secrets are stored in GCP Secret Manager (project: ffe-cicd)
# Naming convention: social-engine-{env}-{var-name}
#
# Pull secrets locally:
#   ./scripts/secrets/pull-secrets.sh dev
#
# Push new secrets to GCP SM:
#   ./scripts/secrets/push-secrets.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk Auth
# GCP SM: social-engine-dev-clerk-publishable-key / social-engine-prod-clerk-publishable-key
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key-here

# GCP SM: social-engine-dev-clerk-secret-key / social-engine-prod-clerk-secret-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key-here

# GCP SM: social-engine-dev-clerk-webhook-secret / social-engine-prod-clerk-webhook-secret
CLERK_WEBHOOK_SECRET=whsec_your-clerk-webhook-secret-here

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# -----------------------------------------------------------------------------
# Convex (Real-time Database)
# GCP SM: social-engine-dev-convex-url / social-engine-prod-convex-url
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# GCP SM: social-engine-dev-convex-deployment / social-engine-prod-convex-deployment
CONVEX_DEPLOYMENT=your-convex-deployment-slug

# -----------------------------------------------------------------------------
# Zernio (Social Posting API)
# GCP SM: social-engine-dev-zernio-api-key / social-engine-prod-zernio-api-key
# -----------------------------------------------------------------------------
ZERNIO_API_KEY=sk_your-zernio-api-key-here

# -----------------------------------------------------------------------------
# Google / Gemini API
# GCP SM: social-engine-dev-google-api-key / social-engine-prod-google-api-key
# (Key from TTA GCP project — has Gemini + Maps access)
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=your-google-api-key-here
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# -----------------------------------------------------------------------------
# Analytics — PostHog
# GCP SM: social-engine-dev-posthog-key / social-engine-prod-posthog-key
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key-here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Error Tracking — Sentry
# GCP SM: social-engine-dev-sentry-dsn / social-engine-prod-sentry-dsn
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-key@sentry.io/your-project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_ORG=firefly-events-inc
SENTRY_PROJECT=social-engine
# Required for source map upload during build (Vercel env var)
SENTRY_AUTH_TOKEN=sntrys_your-sentry-auth-token-here

# -----------------------------------------------------------------------------
# Stripe (Billing)
# GCP SM: social-engine-dev-stripe-secret-key / social-engine-prod-stripe-secret-key
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here

# Stripe Price IDs (from Stripe dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly
STRIPE_PRICE_STARTER_ANNUAL=price_starter_annual
STRIPE_PRICE_BASIC_MONTHLY=price_basic_monthly
STRIPE_PRICE_BASIC_ANNUAL=price_basic_annual
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual
STRIPE_PRICE_BUSINESS_MONTHLY=price_business_monthly
STRIPE_PRICE_BUSINESS_ANNUAL=price_business_annual
STRIPE_PRICE_AGENCY_MONTHLY=price_agency_monthly
STRIPE_PRICE_AGENCY_ANNUAL=price_agency_annual

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
