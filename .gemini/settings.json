{
  "mcpServers": {
    "linear-server": {
      "command": "npx",
      "args": ["-y", "@mseep/linear-mcp"],
      "env": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}"
      },
      "trust": true
    },
    "frame0": {
      "command": "npx",
      "args": ["-y", "frame0-mcp-server"],
      "trust": true
    },
    "stripe": {
      "command": "npx",
      "args": ["-y", "@stripe/mcp", "--tools=all"],
      "env": {
        "STRIPE_SECRET_KEY": "${STRIPE_SECRET_KEY}"
      },
      "trust": true
    }
  }
}
