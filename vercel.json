{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm turbo run build --filter=@ffe/dashboard",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "ignoreCommand": "npx turbo-ignore @ffe/dashboard",
  "crons": [
    {
      "path": "/api/newsletter",
      "schedule": "0 9 * * 1"
    }
  ]
}
